# ─── Community moderation ────────────────────────────────────────────────────
# Required. Set a strong random string in production (openssl rand -hex 32).
ADMIN_TOKEN=hn-admin-local
# Salt for anonymizing submitter IPs. Change in production.
HASH_SALT=hn-local-salt

# ─── Supabase (production persistence) ───────────────────────────────────────
# If set, all tips/reports/opportunities/updates are stored in Supabase.
# If unset, a local .data/community-store.json file is used (dev only).
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser — server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twilio SMS (optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Alerts: EPA AirNow (optional) ───────────────────────────────────────────
# Free key from https://docs.airnowapi.org/account/request/. Enables the
# air-quality alert source. While unset, keep the epa-airnow-current row in
# data/alerts.sources.json disabled (enabled:false) so it never reports as failed.
AIRNOW_API_KEY=your_airnow_api_key

# ─── Deployment ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
