# ─── Community moderation ────────────────────────────────────────────────────
# Required. Set a strong random string in production (openssl rand -hex 32).
ADMIN_TOKEN=hn-admin-local
# Salt for anonymizing submitter IPs. Change in production.
HASH_SALT=hn-local-salt

# ─── Supabase (production persistence) ───────────────────────────────────────
# If set, all tips/reports/opportunities/updates are stored in Supabase.
# If unset, a local .data/community-store.json file is used (dev only).
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser — server-side only.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Twilio SMS (optional) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Alerts: EPA AirNow (optional) ───────────────────────────────────────────
# Free key from https://docs.airnowapi.org/account/request/. Enables the
# air-quality alert source. While unset, keep the epa-airnow-current row in
# data/alerts.sources.json disabled (enabled:false) so it never reports as failed.
AIRNOW_API_KEY=your_airnow_api_key

# ─── NYC API Portal (optional) ───────────────────────────────────────────────
# Free, self-serve subscription key from https://api-portal.nyc.gov/ — sign up,
# subscribe to the "NYC 311 Public Developers" product (which also unlocks the
# Events Calendar API), and paste the key here. Sent as the Ocp-Apim-Subscription-Key
# header. Enables the nyc-events-calendar source (data/community.sources.json);
# while unset, keep that row disabled (enabled:false) so it never reports as failed.
NYC_API_KEY=your_nyc_api_subscription_key

# ─── NYC 311 (optional) ──────────────────────────────────────────────────────
# Subscription key for the api.nyc.gov "nyc-311-public-api" product (separate
# subscription from NYC_API_KEY above). Only needed if the 311 panel's source
# (data/nyc311.sources.json) is switched from NYC Open Data (Socrata, no key) to
# the api.nyc.gov GetAssets operation; sent as Ocp-Apim-Subscription-Key.
NYC_311_KEY=your_nyc_311_subscription_key
# Optional NYC Open Data (Socrata) app token — raises rate limits for the 311
# Service Requests source. Works without it; the header is dropped when unset.
NYC_OPENDATA_APP_TOKEN=your_socrata_app_token

# ─── Deployment ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=production
NEXT_PUBLIC_API_URL=https://your-domain.vercel.app
